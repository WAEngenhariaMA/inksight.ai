# Front-end local. Use vazio para proxy local do Vite.
VITE_API_BASE_URL=

# Provider de imagem usado pelo backend: openai, replicate ou pollinations.
IMAGE_PROVIDER=openai

# OpenAI texto + imagem. Nunca coloque estas chaves no front-end.
OPENAI_API_KEY=
OPENAI_TEXT_MODEL=gpt-5
OPENAI_IMAGE_MODEL=gpt-image-1
OPENAI_IMAGE_SIZE=1024x1536

# Replicate opcional. Usado quando IMAGE_PROVIDER=replicate.
REPLICATE_API_TOKEN=
REPLICATE_MODEL=

# Supabase. Service role fica somente no backend.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# SaaS / creditos.
ENABLE_CREDIT_SYSTEM=true
ENABLE_MANUAL_CREDIT_ADMIN=true

# Backend local legado.
PORT=8787
